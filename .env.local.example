```bash
# GitHub Personal Access Token（需要 repo 权限）
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxx

# 目标仓库，格式：owner/repo
REPO=caslanbigeyes/story

# 后台发布接口认证 Token（自定义任意字符串）
PUBLISH_TOKEN=your_publish_token

# ========== 发布服务切换（可选） ==========
# 不填：使用 Next.js 自带的 /api/publish（需配置 GITHUB_TOKEN / REPO / PUBLISH_TOKEN）
# 填上：使用 Cloudflare Worker 发布（Worker 自己管理 secrets，前端只需知道 URL）
# NEXT_PUBLIC_PUBLISH_ENDPOINT=https://story-blog-publisher.xxx.workers.dev

# ========== Giscus 评论配置（可选，不填则评论区隐藏） ==========
NEXT_PUBLIC_GISCUS_REPO=caslanbigeyes/story
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

```
